function pswGen(len){
  let chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890!@#$&";
  let password = "";
  for(let i =0 ;i<len;i++){
    let randomIndex = Math.floor(Math.random() * chars.length);
    password += chars[randomIndex];
  }
  return password;
}

let password = pswGen(8);
console.log(password);
